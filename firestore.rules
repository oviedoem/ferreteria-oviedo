rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNCIONES HELPER ──────────────────────────────────────
    function esAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function esVendedor() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendedor';
    }

    function estaAutenticado() {
      return request.auth != null;
    }

    function esElMismoUsuario(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── USUARIOS ──────────────────────────────────────────────
    // Admin: lectura/escritura total
    // Cada usuario: solo lee su propio documento
    match /users/{userId} {
      allow read: if esAdmin() || esElMismoUsuario(userId);
      // FIX REGISTRO V36.9i: create self (nuevo usuario guarda su perfil),
      // update/delete solo admin. Evita escalada de privilegios via role.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.role in ['cliente', 'vendedor'];
      allow update, delete: if esAdmin();
    }

    // ── COTIZACIONES ──────────────────────────────────────────
    // Admin y vendedor: lectura total
    // Cliente: solo lee SUS cotizaciones (por uid)
    // Escritura: cualquier autenticado puede crear (vendedor crea para cliente)
    match /cotizaciones/{cotId} {
      allow read: if esAdmin() || esVendedor() ||
                    (estaAutenticado() && resource.data.clienteUid == request.auth.uid);
      allow create: if estaAutenticado() ||
                    // Invitado sin cuenta: esquema acotado, sin leer nada de vuelta
                    (request.resource.data.app == 'Invitado'
                      && request.resource.data.user == 'Invitado'
                      && request.resource.data.deviceId is string
                      && request.resource.data.deviceId.size() < 80
                      && request.resource.data.detalle is list
                      && request.resource.data.detalle.size() <= 30
                      && request.resource.data.total is number);
      allow update, delete: if esAdmin();
    }

    // ── CONFIG ────────────────────────────────────────────────
    // Lectura pública (panel-cliente lee config/precios antes del login)
    // Escritura: solo admin
    match /config/{docId} {
      allow read: if true;
      allow write: if esAdmin();
    }
    // Subcolecciones de config (ej: config/banner/historial, config/banner/carrusel)
    match /config/{docId}/{subColl}/{subId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ── SESIONES ACTIVAS ──────────────────────────────────────
    // Cada usuario escribe/lee su propia sesión
    // Admin lee todas
    match /sesiones_activas/{uid} {
      allow read, write: if esAdmin() || esElMismoUsuario(uid);
    }

    // ── SESIONES LOG ──────────────────────────────────────────
    // docId = uid + '_' + deviceId — solo el propio usuario actualiza su log
    match /sesionesLog/{docId} {
      allow read: if esAdmin();
      allow create: if estaAutenticado();
      allow update: if esAdmin() || (estaAutenticado() && resource.data.uid == request.auth.uid);
    }

    // ── AUDIT LOG ─────────────────────────────────────────────
    // solo admins crean registros — evita que usuarios inyecten logs falsos
    match /auditLog/{docId} {
      allow read: if esAdmin();
      allow create: if esAdmin();
    }

    // ── LOG MODO INVITADO (panel-cliente sin cuenta) ──────────
    // Escritura abierta (el invitado no está autenticado) pero validada por
    // esquema estricto — solo 3 campos, sin precios, sin datos de productos.
    // Lectura solo admin (seguimiento de uso en panel-admin).
    match /invitadosLog/{docId} {
      allow read: if esAdmin();
      allow create: if request.resource.data.keys().hasOnly(['deviceId','usados','ts'])
                    && request.resource.data.deviceId is string
                    && request.resource.data.deviceId.size() < 80
                    && request.resource.data.usados is int
                    && request.resource.data.usados >= 1 && request.resource.data.usados <= 10
                    && request.resource.data.ts == request.time;
      allow update, delete: if false;
    }

    // ── TOKEN DE ACCESO A data/ (mitigación V37.28 — ruta oculta) ──
    // El nombre de carpeta donde vive data/*.json sensible rota en cada
    // corrida del pipeline. Solo admin/vendedor autenticados pueden leerlo
    // para construir la URL real. Escritura: solo el pipeline (Admin SDK
    // bypassa esta regla) — bloqueada desde el cliente.
    match /dataAccessToken/{docId} {
      allow read: if esAdmin() || esVendedor();
      allow write: if false;
    }

    // ── PROMOS ────────────────────────────────────────────────
    // Lectura pública (catálogo visible sin login)
    // Escritura solo admin
    match /promos/{docId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ── CUPONES ──────────────────────────────────────────────
    match /cupones/{docId} {
      allow read: if estaAutenticado();
      allow write: if esAdmin() || esVendedor();
    }

    // ── NOTIFICACIONES ────────────────────────────────────────
    match /notificaciones/{docId} {
      allow read: if estaAutenticado();
      allow create: if estaAutenticado();
      allow update, delete: if esAdmin() || esVendedor();
    }

    // ── TAREAS CLAUDE (buzon) ─────────────────────────────────
    match /tareasClaude/{docId} {
      allow read, write: if esAdmin();
    }

    // ── PRECIOS (1 doc — split seguro V37.28) ─────────────────
    // precios/catalogo: mapa {codigo: {p: precioIVA, s: stock}} para todos los productos.
    // Solo usuarios autenticados NO anónimos pueden leer.
    // Escritura: exclusiva del pipeline vía Admin SDK (bypassa estas reglas).
    match /precios/{docId} {
      allow read: if request.auth != null
                  && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow write: if false;
    }

    // ── BLOQUEO POR DEFECTO ───────────────────────────────────
    // Todo lo que no esté listado arriba → denegado
    // Incluye: productos, solicitudes_cupon, sessions (obsoletas)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
