rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── FUNCIONES HELPER ──────────────────────────────────────
    function esAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function esVendedor() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'vendedor';
    }

    function estaAutenticado() {
      return request.auth != null;
    }

    function esElMismoUsuario(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── USUARIOS ──────────────────────────────────────────────
    // Admin: lectura/escritura total
    // Cada usuario: solo lee su propio documento
    match /users/{userId} {
      allow read: if esAdmin() || esElMismoUsuario(userId);
      allow write: if esAdmin();
    }

    // ── COTIZACIONES ──────────────────────────────────────────
    // Admin y vendedor: lectura total
    // Cliente: solo lee SUS cotizaciones (por uid)
    // Escritura: cualquier autenticado puede crear (vendedor crea para cliente)
    match /cotizaciones/{cotId} {
      allow read: if esAdmin() || esVendedor() ||
                    (estaAutenticado() && resource.data.clienteUid == request.auth.uid);
      allow create: if estaAutenticado();
      allow update, delete: if esAdmin();
    }

    // ── CONFIG ────────────────────────────────────────────────
    // Lectura pública (panel-cliente lee config/precios antes del login)
    // Escritura: solo admin
    match /config/{docId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ── SESIONES ACTIVAS ──────────────────────────────────────
    // Cada usuario escribe/lee su propia sesión
    // Admin lee todas
    match /sesiones_activas/{uid} {
      allow read, write: if esAdmin() || esElMismoUsuario(uid);
    }

    // ── SESIONES LOG ──────────────────────────────────────────
    match /sesionesLog/{docId} {
      allow read: if esAdmin();
      allow create: if estaAutenticado();
      allow update: if esAdmin() || estaAutenticado();
    }

    // ── AUDIT LOG ─────────────────────────────────────────────
    match /auditLog/{docId} {
      allow read: if esAdmin();
      allow create: if estaAutenticado();
    }

    // ── PROMOS ────────────────────────────────────────────────
    // Lectura pública (catálogo visible sin login)
    // Escritura solo admin
    match /promos/{docId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // ── CUPONES ──────────────────────────────────────────────
    match /cupones/{docId} {
      allow read: if estaAutenticado();
      allow write: if esAdmin() || esVendedor();
    }

    // ── NOTIFICACIONES ────────────────────────────────────────
    match /notificaciones/{docId} {
      allow read: if estaAutenticado();
      allow write: if esAdmin() || esVendedor();
    }

    // ── TAREAS CLAUDE (buzon) ─────────────────────────────────
    match /tareasClaude/{docId} {
      allow read, write: if esAdmin();
    }

    // ── BLOQUEO POR DEFECTO ───────────────────────────────────
    // Todo lo que no esté listado arriba → denegado
    // Incluye: productos, solicitudes_cupon, sessions (obsoletas)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
