rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /sessions/{sessionId} {
      allow read, write: if true;
    }

    match /sesiones_activas/{sesId} {
      allow read, write: if true;
    }

    match /cotizaciones/{cotizId} {
      allow read, write: if true;
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if true;
    }

    match /promos/{promoId} {
      allow read: if true;
      allow write: if true;
    }

    match /notificaciones/{notiId} {
      allow read, write: if true;
    }

    match /productos/{prodId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
